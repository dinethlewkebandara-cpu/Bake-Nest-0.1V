rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 6 &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) && 
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
                      
      allow update: if isOwner(userId) && 
                      isVerified() && // Must be verified to update
                      isValidId(userId) && 
                      isValidUser(incoming()) && 
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt', 'photoURL']);
                      
      allow delete: if false;
    }

    // 2. Products (Public read, Admin write)
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // 3. Custom Cakes (Verified Owner read/write)
    function isValidCustomCake(data) {
      return data.userId == request.auth.uid &&
             data.cakeType is string &&
             data.flavor is string &&
             data.status in ['pending', 'confirmed', 'in-progress', 'completed'];
    }

    match /custom_cakes/{bookingId} {
      allow create: if isVerified() && isValidCustomCake(incoming()) && incoming().createdAt == request.time;
      allow read, update: if isVerified() && existing().userId == request.auth.uid;
    }

    // 4. Reviews (Public read, Verified write)
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified() && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow update, delete: if isVerified() && existing().userId == request.auth.uid;
    }

    // 5. Orders (Verified Owner read/write)
    match /orders/{orderId} {
      allow create: if isVerified() && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow read: if isVerified() && existing().userId == request.auth.uid;
    }
  }
}
